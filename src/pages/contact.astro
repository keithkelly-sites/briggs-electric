---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import mapImg from '../assets/images/map.png';
---

<Layout title="Contact | Briggs Electric — Pittsburgh, PA" description="Get a free quote from Briggs Electric. Call or text 412-498-4979. Serving Bridgeville, PA and the greater Pittsburgh area.">
  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="section-label">Contact</span>
      <h1>Call or text.<br />Talk to the owner.</h1>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="contact-section">
    <div class="container">
      <div class="contact-grid">
        <!-- Info Side -->
        <div class="contact-info reveal">
          <div class="contact-block">
            <h2>Get a free quote</h2>
            <p>We stay in constant communication with our customers until the job is done. Call, text, or email for a free quote on any project.</p>
          </div>

          <div class="contact-block">
            <h3>Phone</h3>
            <a href="tel:4124984979" class="contact-link contact-link--phone">412-498-4979</a>
            <p class="contact-note">Call or text. You'll reach the owner.</p>
          </div>

          <div class="contact-block">
            <h3>Email</h3>
            <a href="mailto:briggs.electric@yahoo.com" class="contact-link">briggs.electric@yahoo.com</a>
          </div>

          <div class="contact-block">
            <h3>Address</h3>
            <address>
              1597 Washington Pike<br />
              Suite A38-125<br />
              Bridgeville, PA 15017
            </address>
          </div>

          <div class="contact-block">
            <h3>Hours</h3>
            <div class="hours-table">
              <div class="hours-row">
                <span>Monday - Saturday</span>
                <span>6:00 AM - 6:00 PM</span>
              </div>
              <div class="hours-row">
                <span>Sunday</span>
                <span>Closed</span>
              </div>
            </div>
          </div>

          <div class="contact-block">
            <h3>Follow Us</h3>
            <div class="contact-social">
              <a href="https://www.facebook.com/profile.php?id=61556533050294" target="_blank" rel="noopener noreferrer" class="social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                Facebook
              </a>
              <a href="https://www.instagram.com/briggselectricpgh/" target="_blank" rel="noopener noreferrer" class="social-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                Instagram
              </a>
            </div>
          </div>
        </div>

        <!-- Form + Map Side -->
        <div class="contact-right reveal reveal-delay-2">
          <div class="contact-form-wrap">
            <h2 class="form-heading">Send us a message</h2>
            <form action="#" method="POST" class="contact-form">
              <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required autocomplete="name" />
              </div>
              <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" />
              </div>
              <div class="form-group">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required autocomplete="email" />
              </div>
              <div class="form-group">
                <label for="message">Message</label>
                <textarea id="message" name="message" rows="4" required></textarea>
              </div>
              <button type="submit" class="btn btn--primary">Send Message</button>
            </form>
          </div>

          <div class="contact-map">
          <a href="https://www.google.com/maps/dir/?api=1&destination=1597+Washington+Pike+Bridgeville+PA+15017" target="_blank" rel="noopener noreferrer" class="map-card">
            <Image src={mapImg} alt="Map showing Briggs Electric location in Bridgeville, PA" loading="lazy" width={800} height={500} class="map-image" />
            <div class="map-bar">
              <span>Briggs Electric - Bridgeville, PA</span>
              <span>Get directions &rarr;</span>
            </div>
          </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Hiring CTA -->
  <section class="hiring-section">
    <div class="container--narrow">
      <div class="hiring-box reveal">
        <span class="section-label">Careers</span>
        <h2>Always hiring.</h2>
        <p>Looking for licensed electricians who want to work with serious equipment on interesting projects. Pools, generators, heavy machinery. Not just pulling wire through drywall.</p>
        <a href="mailto:briggs.electric@yahoo.com?subject=Job%20Inquiry" class="btn btn--outline">Apply by Email</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: calc(var(--space-2xl) + 4rem) 0 var(--space-xl);
    background: var(--black-pure);
    border-bottom: 1px solid var(--border);
  }

  .page-hero h1 {
    font-size: clamp(2.5rem, 7vw, 5.5rem);
    font-weight: 600;
  }

  .section-label {
    display: block;
    font-family: var(--font-display);
    font-size: 0.75rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--electric);
    margin-bottom: var(--space-sm);
  }

  /* ---- Contact Section ---- */
  .contact-section {
    padding: var(--space-2xl) 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .contact-block {
    margin-bottom: var(--space-lg);
  }

  .contact-block:last-child {
    margin-bottom: 0;
  }

  .contact-block h2 {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    margin-bottom: var(--space-sm);
    text-transform: none;
  }

  .contact-block h3 {
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .contact-block p {
    color: var(--text-muted);
    max-width: 40ch;
  }

  .contact-note {
    font-size: 0.85rem;
    margin-top: 0.25rem;
  }

  .contact-link {
    font-size: 1rem;
    color: var(--text);
    transition: color 0.3s;
    display: inline-block;
  }

  .contact-link:hover {
    color: var(--electric);
  }

  .contact-link--phone {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--electric);
  }

  address {
    font-style: normal;
    color: var(--text);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  .hours-table {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .hours-row {
    display: flex;
    justify-content: space-between;
    max-width: 20rem;
    font-size: 0.9rem;
    color: var(--text);
  }

  .contact-social {
    display: flex;
    gap: 1.5rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text);
    transition: color 0.3s;
  }

  .social-link:hover {
    color: var(--electric);
  }

  /* ---- Form ---- */
  .contact-form-wrap {
    margin-bottom: var(--space-lg);
  }

  .form-heading {
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--text-muted);
    margin-bottom: var(--space-md);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-family: var(--font-display);
    font-size: 0.7rem;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-muted);
  }

  .form-group input,
  .form-group textarea {
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.75rem 1rem;
    transition: border-color 0.3s;
    min-height: 44px;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    border-color: var(--electric);
    outline: none;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  /* ---- Map ---- */
  .map-card {
    display: block;
    position: relative;
    overflow: hidden;
    border: 1px solid var(--border);
    transition: border-color 0.3s;
  }

  .map-card:hover {
    border-color: var(--electric-dim);
  }

  .map-image {
    width: 100%;
    height: auto;
    display: block;
  }

  .map-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: var(--surface);
    font-family: var(--font-display);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---- Hiring ---- */
  .hiring-section {
    padding: 0 0 var(--space-2xl);
  }

  .hiring-box {
    padding: var(--space-xl);
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .hiring-box h2 {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    margin-bottom: var(--space-sm);
  }

  .hiring-box p {
    color: var(--text-muted);
    margin-bottom: var(--space-lg);
    max-width: 55ch;
  }
</style>
